  },
  "dependencies": {
    "@opencode-ai/sdk": "latest",
    "discord.js": "^14.16.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
