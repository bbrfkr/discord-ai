{
  "name": "discord-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "別デプロイの opencode-server に接続し、Discord チャンネルを起点に AI agent へ作業を依頼する Discord bot",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "cli": "tsx src/cli.ts",
    "bot": "tsx src/discord/bot.ts",
