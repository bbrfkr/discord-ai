# opencode serve の待ち受け先（ローカルで npm run cli/bot する時に使用）。
# docker compose 利用時は compose 側が http://opencode:4096 に上書きするため不要。
OPENCODE_BASE_URL=http://127.0.0.1:4096

# 使用モデル（任意）。未指定なら opencode サーバの既定モデルを使用する。
# 例: bbrfkr-llm / bbrfkr-llm-medium または bbrfkr-llm-larget
# OPENCODE_PROVIDER_ID=bbrfkr-llm
# OPENCODE_MODEL_ID=bbrfkr-llm-medium

# --- Discord bot 用（npm run bot で必須） ---
# Bot のトークン（Developer Portal > Bot > Reset Token）
DISCORD_TOKEN=
# 監視対象チャンネルの ID（Discordで開発者モードON → チャンネル右クリック → IDをコピー）
DISCORD_TARGET_CHANNEL_ID=

# --- コンテナ化した opencode 用（docker compose で必須） ---
# litellm 互換エンドポイントと API キー（opencode/opencode.json から {env:...} で参照）。
LITELLM_BASE_URL=https://your-litellm-host/v1
LITELLM_API_KEY=

# --- DOCS_REPO_PATH（必須）---
# コンテナの にマウントする n8n ワークフロー仕様 のホスト側絶対パス。
DOCS_REPO_PATH=

# --- GitHub 連携（AI に git の pull/commit/push を任せる）---
# Fine-grained PAT。対象リポジトリの Contents: Read and write（PR も使うなら Pull requests も）。
# gh が GH_TOKEN を自動で読むためブラウザ認証は不要。
GH_TOKEN=
# AI が作るコミットの著者情報（compose で GIT_AUTHOR_*/GIT_COMMITTER_* に展開される）。
GIT_USER_NAME=
GIT_USER_EMAIL=

# n8n workflow用
WORKFLOW_TOKEN=
